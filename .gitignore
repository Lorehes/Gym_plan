# ==============================
# GymPlan .gitignore
# ==============================

# ==============================
# Gradle
# ==============================
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# ==============================
# IntelliJ IDEA
# ==============================
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# ==============================
# VS Code
# ==============================
.vscode/
!.vscode/extensions.json

# ==============================
# macOS
# ==============================
.DS_Store
.AppleDouble
.LSOverride

# ==============================
# 환경 변수 & 시크릿 (절대 커밋 금지)
# ==============================
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.jks
application-local.yml
application-local.yaml
application-secret.yml
application-secret.yaml
**/src/main/resources/application-local*.yml
**/src/main/resources/application-secret*.yml

# ==============================
# 로그
# ==============================
*.log
logs/
**/logs/

# ==============================
# Spring Boot
# ==============================
**/target/
spring-shell.log

# ==============================
# Kotlin
# ==============================
*.class
kotlin-js-store/

# ==============================
# Node.js (React / React Native)
# ==============================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ==============================
# React Native / Expo
# ==============================
clients/mobile/.expo/
clients/mobile/dist/
clients/mobile/web-build/
clients/mobile/android/
clients/mobile/ios/
clients/mobile/*.jks
clients/mobile/*.p8
clients/mobile/*.p12
clients/mobile/*.mobileprovision
clients/mobile/*.orig.*

# ==============================
# React Web (Vite)
# ==============================
clients/web/dist/
clients/web/.vite/

# ==============================
# Docker
# ==============================
infra/docker-compose/.env

# ==============================
# Kubernetes / Helm
# ==============================
infra/k8s/secrets/
infra/helm/secrets/
*.kubeconfig

# ==============================
# Vault
# ==============================
vault-token
.vault-token

# ==============================
# 테스트 리포트
# ==============================
**/test-results/
**/reports/

# ==============================
# 임시 파일
# ==============================
*.tmp
*.bak
*.swp
*~

# ==============================
# Docs
# ==============================
docs/
.claude/*