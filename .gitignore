# Gradle
# ==============================
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# ==============================
# IntelliJ IDEA
# ==============================
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# ==============================
# VS Code
# ==============================
.vscode/
!.vscode/extensions.json

# ==============================
# macOS
# ==============================
.DS_Store
.AppleDouble
.LSOverride

# ==============================
# 환경 변수 & 시크릿 (절대 커밋 금지)
# ==============================
# 정책: dev/local 전용이어도 보안 관련 파일은 일체 추적하지 않는다.
# .env.example 같은 placeholder/template 도 비밀번호 패턴이 들어가면 누출 위험 → 차단.
.env
.env.*
.env.example
**/.env
**/.env.*
**/.env.example
*.key
*.pem
*.p12
*.jks
*.p8
*.pfx
*.crt
*.cer
*.der

# ── Spring Boot application-*.yml 차단 정책 ──
# 일반 application.yml / application-{env}.yml 은 ${ENV_VAR} 참조만 사용 → 추적 허용.
# 시크릿이 들어갈 가능성이 있는 변형은 광범위하게 차단 (편집증적 안전망).
application-local.yml
application-local.yaml
application-secret.yml
application-secret.yaml
application-secrets.yml
application-secrets.yaml
application-private.yml
application-private.yaml
application-personal.yml
application-personal.yaml
**/application-local.yml
**/application-local.yaml
**/application-secret.yml
**/application-secret.yaml
**/application-secrets.yml
**/application-secrets.yaml
**/application-private.yml
**/application-private.yaml
**/application-personal.yml
**/application-personal.yaml
**/application-*-secret.yml
**/application-*-secret.yaml
**/application-*-secrets.yml
**/application-*-secrets.yaml
**/application-*-private.yml
**/application-*-private.yaml

# ── 시크릿 명명 규칙 광범위 차단 ──
# 파일명에 secret / secrets / private / credential 이 prefix·중간·suffix 어디든 포함되면
# 설정 파일 확장자 (yml/yaml/json/properties/conf/env) 는 무조건 차단.
# 코드 파일 (.kt/.java/.ts) 은 SecretManager 같은 정상 클래스명을 살리기 위해 제외.
*secret*.yml
*secret*.yaml
*secret*.json
*secret*.properties
*secret*.conf
*secret*.env
*secrets*.yml
*secrets*.yaml
*secrets*.json
*secrets*.properties
*secrets*.conf
*secrets*.env
*credential*.yml
*credential*.yaml
*credential*.json
*credential*.properties
*credentials*.yml
*credentials*.yaml
*credentials*.json
*credentials*.properties
*creds*.yml
*creds*.yaml
*creds*.json
*creds*.properties
*apikey*.yml
*apikey*.yaml
*apikey*.json
*api-key*.yml
*api-key*.yaml
*api-key*.json
*api_key*.yml
*api_key*.yaml
*api_key*.json
*-token.yml
*-token.yaml
*-token.json
*-key.json
*-private.yml
*-private.yaml
*-private.json
*.private.yml
*.private.yaml
*.private.json
**/secret.json
**/secrets.json
**/secret.yml
**/secrets.yml
**/secret.yaml
**/secrets.yaml
**/credentials.json
**/credentials.yml
**/credentials.yaml

# ── 시크릿 디렉토리 차단 ──
secret/
secrets/
**/secret/
**/secrets/
**/.secrets/
**/.secret/

# ── 클라우드/외부 서비스 자격증명 패턴 ──
**/firebase-adminsdk*.json
**/google-services*.json
**/GoogleService-Info.plist
**/serviceAccountKey*.json
**/aws-credentials*
**/gcp-service-account*.json
.aws/
