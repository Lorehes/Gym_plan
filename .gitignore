# ==============================
# GymPlan .gitignore
# ==============================

# ==============================
# Gradle
# ==============================
.gradle/
build/
gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# ==============================
# IntelliJ IDEA
# ==============================
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# ==============================
# VS Code
# ==============================
.vscode/
!.vscode/extensions.json

# ==============================
# macOS
# ==============================
.DS_Store
.AppleDouble
.LSOverride

# ==============================
# 환경 변수 & 시크릿 (절대 커밋 금지)
# ==============================
# 정책: dev/local 전용이어도 보안 관련 파일은 일체 추적하지 않는다.
# .env.example 같은 placeholder/template 도 비밀번호 패턴이 들어가면 누출 위험 → 차단.
.env
.env.*
.env.example
**/.env.example
*.key
*.pem
*.p12
*.jks
*application*.yml
*.yaml

# Vault 설정/스크립트 일체 차단 (시드 토큰, 키 생성 로직 등 보안 절차 포함)
infra/vault/

# ==============================
# 로그
# ==============================
*.log
logs/
**/logs/

# ==============================
# Spring Boot
# ==============================
**/target/
spring-shell.log

# ==============================
# Kotlin
# ==============================
*.class
kotlin-js-store/

# ==============================
# Node.js (React / React Native)
# ==============================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ==============================
# React Native / Expo
# ==============================
clients/mobile/.expo/
clients/mobile/dist/
clients/mobile/web-build/
clients/mobile/android/
clients/mobile/ios/
clients/mobile/*.jks
clients/mobile/*.p8
clients/mobile/*.p12
clients/mobile/*.mobileprovision
clients/mobile/*.orig.*

# ==============================
# React Web (Vite)
# ==============================
clients/web/dist/
clients/web/.vite/

# ==============================
# Docker
# ==============================
infra/docker-compose/.env

# ==============================
# Kubernetes / Helm
# ==============================
infra/k8s/secrets/
infra/helm/secrets/
*.kubeconfig

# ==============================
# Vault
# ==============================
vault-token
.vault-token

# ==============================
# 테스트 리포트
# ==============================
**/test-results/
**/reports/

# ==============================
# 임시 파일
# ==============================
*.tmp
*.bak
*.swp
*~

# ==============================
# Docs
# ==============================
# docs/ 는 1인 개발 + Claude 협업 컨텍스트로 추적한다.
# 단, 변환된 바이너리 명세는 차단.
docs/**/*.docx

# ==============================
# .claude — Claude Code 협업 자산
# ==============================
# 모든 .claude 파일 차단 (sessions, cache, todo, CLAUDE.md, skills 등)
.claude/